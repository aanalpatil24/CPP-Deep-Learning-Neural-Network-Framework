{
    "configurations": [
        {
            "name": "Linux",
            "includePath": ["${workspaceFolder}/**"],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "compilerArgs": [
                "-mavx512f",
                "-mavx512dq"
            ],
            "intelliSenseMode": "linux-gcc-x64"
        },
        {
            "name": "Win32",
            "includePath": ["${workspaceFolder}/**"],
            "compilerPath": "cl.exe",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "compilerArgs": [
                "/Zc:__cplusplus",
                "/arch:AVX512"
            ],
            "intelliSenseMode": "windows-msvc-x64"
        }
    ],
    "version": 4
}